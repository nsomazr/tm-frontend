# Environment configuration template
#
# Vite loads env files in this priority (highest wins):
#   .env.development.local  →  .env.development  →  .env.local  →  .env
# The dev server (vite / npm run dev) runs in "development" mode, so
# .env.development is applied and overrides .env.
# Production builds (vite build / deploy.sh) run in "production" mode and
# ignore .env.development.
#
# Recommended setup:
#   - .env              → production values (gitignored, per-machine)
#   - .env.development  → local values (used automatically by the dev server)
#
# Copy this file to whichever you need and fill in the values.

# --- Local development (.env.development) ---
VITE_API_URL=http://localhost:8085/api/v1
VITE_PESAPAL_ENV=sandbox
VITE_ALLOWED_REDIRECT_HOSTS=localhost,127.0.0.1

# ngrok: tunnel frontend (ngrok http 3085) and proxy API through the same URL
# VITE_API_URL=/api/v1

# --- Production (.env) ---
# VITE_API_URL=https://api.terrameta.5ggeology.com/api/v1
# VITE_PESAPAL_ENV=live
# VITE_ALLOWED_REDIRECT_HOSTS=terrameta.5ggeology.com,www.terrameta.5ggeology.com
